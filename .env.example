# App-side config. Copy to `.env`. ONLY the API base URL belongs here — it is
# inlined into the app bundle at build time. NEVER put the MongoDB URI or any
# secret here; the cluster connection lives exclusively in server/.env.
#
# iOS simulator can reach the dev machine via localhost. A physical phone on
# Expo Go must use your computer's LAN IP, e.g. http://192.168.1.42:4000
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
