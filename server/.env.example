# Copy to server/.env and fill in. NEVER commit the real .env (it is gitignored).
# Rotate the Atlas password if it has ever been shared in plaintext.
MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR-CLUSTER.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=questpic
PORT=4000

# Secret used to sign auth JWTs. Use a long random value in production, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-insecure-secret-change-me
